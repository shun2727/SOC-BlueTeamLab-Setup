<!-- /var/ossec/etc/ossec.conf on the agent (victim VM) -->
<ossec_config>
  <localfile>
    <log_format>apache</log_format>
    <location>/var/log/apache2/access.log</location>
  </localfile>
</ossec_config>

<!--
This alone gets you Wazuh's built-in SQLi detection for free — no custom rule needed yet. Wazuh's default web ruleset already fires:

Rule 31103 — generic suspicious URL pattern (e.g., SQL keywords appearing in a request)
Rule 31106 — a successful SQL injection pattern match (higher-confidence indicator)
-->

<!-- /var/ossec/etc/rules/local_rules.xml on the MANAGER -->
<group name="local,syslog,sql_injection,">

  <rule id="100100" level="10">
    <if_sid>31100</if_sid>
    <url>select |union |insert into|drop table|1=1|' OR '|;--|SLEEP\(|BENCHMARK\(</url>
    <description>SQL Injection attempt detected from $(srcip) targeting $(url)</description>
    <group>web,attack,sql_injection,pci_dss_6.6,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100101" level="13">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>Repeated SQL Injection attempts from $(srcip) — possible automated scan (sqlmap)</description>
    <group>web,attack,sql_injection,frequency,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

</group>

