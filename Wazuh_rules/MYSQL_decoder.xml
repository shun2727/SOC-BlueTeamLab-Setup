<!--claude decoder example 2-->
<decoder name="mysql-querylog">
  <prematch>^\d+\s+\w+</prematch>
  <regex type="pcre2">^(\d+)\s+(\w+)\s+(.*)$</regex>
  <order>id, _action, data</order>
</decoder>

